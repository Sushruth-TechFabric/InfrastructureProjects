        <mxCell id="dns" value="Private DNS Zones&#10;blob · dfs · vault · azuredatabricks" style="sketch=0;html=1;aspect=fixed;shape=image;verticalLabelPosition=bottom;verticalAlign=top;labelPosition=center;align=center;fontSize=11;image=img/lib/azure2/networking/DNS_Zones.svg;" vertex="1" parent="1"><mxGeometry x="400" y="688" width="140" height="56" as="geometry"/></mxCell>

        <!-- SPOKE VNET -->
