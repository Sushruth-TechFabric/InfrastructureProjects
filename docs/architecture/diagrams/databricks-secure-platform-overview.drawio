        <mxCell id="github" value="GitHub Actions (CI/CD)&#10;OIDC federated · no secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;" vertex="1" parent="1"><mxGeometry x="70" y="272" width="180" height="58" as="geometry"/></mxCell>
