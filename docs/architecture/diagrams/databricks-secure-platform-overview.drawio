<mxfile host="app.diagrams.net" type="device">
  <diagram name="Databricks Platform — High Level" id="dbx-overview">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="940" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="Azure Databricks — Secure Platform (High-Level Overview)" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1000" height="30" as="geometry"/></mxCell>
        <mxCell id="sub" value="Identity-gated front-end · private compute &amp; data planes · secretless data access · hub-spoke egress control" style="text;html=1;fontSize=12;align=left;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="40" y="46" width="1100" height="20" as="geometry"/></mxCell>

