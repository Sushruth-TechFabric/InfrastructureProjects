        <mxCell id="lg5t" value="dashed = identity / control · solid = data path" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1276" y="144" width="250" height="22" as="geometry"/></mxCell>

        <!-- ZONE A: ACCESS -->
        <mxCell id="zoneA" value="User &amp; CI/CD Access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=6;dashed=1;dashPattern=6 4;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="240" height="520" as="geometry"/></mxCell>
