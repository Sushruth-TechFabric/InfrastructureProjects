        <mxCell id="ucmeta" value="Unity Catalog Metastore&#10;account-level · 1 per region&#10;(shared-services)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="820" y="130" width="170" height="80" as="geometry"/></mxCell>
        <mxCell id="feNote" value="Front-end is internet-reachable, gated by Entra ID + workspace IP access lists (no front-end Private Link)." style="text;html=1;fontSize=11;align=center;fontColor=#444444;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="350" y="262" width="640" height="34" as="geometry"/></mxCell>

