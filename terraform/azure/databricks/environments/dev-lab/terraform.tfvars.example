# =============================================================================
# environments/dev-lab — EXAMPLE VARIABLES
# -----------------------------------------------------------------------------
# Copy to terraform.tfvars and fill in YOUR values. terraform.tfvars is
# gitignored for this root: every teammate deploys the lab into their own
# subscription with their own IPs/emails/names.
# =============================================================================

# Your subscription: az account show --query id -o tsv
subscription_id = "00000000-0000-0000-0000-000000000000"

# GLOBALLY unique across all of Azure — include your initials or a random
# suffix. 3-24 chars, lowercase letters + digits only.
storage_account_name = "stdbxlabjdoewus3001"

# Your public egress IP(s) for the storage/Key Vault firewalls: curl ifconfig.me
# (Not used for the workspace front-end — that is Entra ID-gated, ADR-0010.)
# Prefer a small range (e.g. "203.0.113.0/24") over one IP so an ISP address
# rotation doesn't lock you out. No /31 or /32 CIDRs (Azure Storage rejects
# them) — bare IPs are fine.
allowed_ip_addresses = ["203.0.113.10"]

# Budget notifications land here at $75 / $120 / $150 (50/80/100% of $150).
budget_contact_emails = ["you@example.com"]

tags = {
  Environment = "lab"
  Owner       = "you@example.com"
  CostCenter  = "personal-learning"
  ManagedBy   = "terraform"
  Project     = "azure-databricks-platform"
}

# ---- Optional overrides (defaults shown) ------------------------------------
# project                  = "dbx"  # short token embedded in every resource name
# location                 = "westus3"
# region_abbrev            = "wus3"
# instance                 = "001"
# cluster_node_type        = "Standard_DS3_v2"
# autotermination_minutes  = 20    # policy-FIXED; 10-60, never 0
# enable_serverless        = true  # false if your account/region lacks serverless
# warehouse_auto_stop_mins = 10
# budget_amount            = 150
