        <mxCell id="leg_net_t" value="Network / VNet / Private Link" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1346" y="44" width="220" height="22" as="geometry"/></mxCell>
        <mxCell id="leg_id" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1316" y="72" width="22" height="14" as="geometry"/></mxCell>
        <mxCell id="leg_id_t" value="Identity / RBAC / managed identity" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1346" y="68" width="220" height="22" as="geometry"/></mxCell>
        <mxCell id="leg_data" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1316" y="96" width="22" height="14" as="geometry"/></mxCell>
        <mxCell id="leg_data_t" value="Data / storage / secrets" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1346" y="92" width="220" height="22" as="geometry"/></mxCell>
        <mxCell id="leg_comp" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1316" y="120" width="22" height="14" as="geometry"/></mxCell>
        <mxCell id="leg_comp_t" value="Compute / governance controls" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1346" y="116" width="220" height="22" as="geometry"/></mxCell>
