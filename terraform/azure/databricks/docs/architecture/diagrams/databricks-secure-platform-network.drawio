        <!-- SPOKE NAT EGRESS (ADR-0007 default) -->
        <mxCell id="natspoke" value="Spoke NAT Gateway — stable egress public IP · NSG outbound allowlist (AzureDatabricks · Entra ID · Storage · Sql · EventHub) + deny-Internet (ADR-0007)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="490" y="1098" width="540" height="38" as="geometry"/></mxCell>

