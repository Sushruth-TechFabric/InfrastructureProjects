<mxfile host="app.diagrams.net" type="device">
  <diagram name="Databricks Secure Platform" id="dbx-secure-net">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1240" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="Azure Databricks — Secure Platform Network Architecture" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1100" height="30" as="geometry"/></mxCell>
        <mxCell id="sub" value="Hub-spoke · VNet injection · Secure Cluster Connectivity + back-end Private Link · identity-gated front-end · fully private data plane · secretless data access · NAT Gateway + NSG egress (ADR-0007 — hub firewall optional)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="40" y="46" width="1180" height="20" as="geometry"/></mxCell>

