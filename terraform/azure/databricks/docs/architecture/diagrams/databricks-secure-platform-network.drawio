        <!-- PE SUBNET -->
        <mxCell id="pesubnet" value="Private Endpoint Subnet (separate from delegated subnets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dde9fb;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=11;align=center;spacingTop=2;" vertex="1" parent="1"><mxGeometry x="490" y="892" width="540" height="200" as="geometry"/></mxCell>
        <mxCell id="pe_dbx" value="Private Endpoint&#10;databricks_ui_api&#10;BACK-END Private Link" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="508" y="948" width="160" height="120" as="geometry"/></mxCell>
