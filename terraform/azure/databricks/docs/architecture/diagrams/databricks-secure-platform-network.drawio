        <mxCell id="leg_sec_t" value="Security boundary (SCC / private-only)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1346" y="140" width="230" height="22" as="geometry"/></mxCell>

        <!-- EXTERNAL ACTORS -->
        <mxCell id="entra" value="Microsoft Entra ID&#10;SSO · Conditional Access (MFA)&#10;OIDC federation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="150" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="users" value="Users &amp; Admins&#10;browser · CLI · Terraform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="252" width="200" height="64" as="geometry"/></mxCell>
        <mxCell id="gha" value="GitHub Actions Runner&#10;OIDC federated credential&#10;(repo + branch/env scoped) · no stored secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="348" width="200" height="78" as="geometry"/></mxCell>

        <!-- DATABRICKS CONTROL PLANE (Microsoft-managed) -->
        <mxCell id="cp" value="Databricks Control Plane — Microsoft-managed subscription" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="660" y="110" width="600" height="330" as="geometry"/></mxCell>
        <mxCell id="wsapi" value="Workspace UI &amp; REST API&#10;FRONT-END: internet-reachable&#10;gated by Entra ID (no IP access lists — ADR-0010)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="685" y="170" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="scc" value="SCC Relay&#10;reverse-tunnel endpoint&#10;(control plane → clusters via outbound tunnel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="685" y="300" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="ucmeta" value="Unity Catalog Metastore&#10;ACCOUNT-LEVEL · one per region&#10;shared by all workspaces&#10;(created via shared-services state,&#10;account-level databricks provider)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="980" y="200" width="250" height="120" as="geometry"/></mxCell>

        <!-- CUSTOMER TENANT BOUNDARY -->
        <mxCell id="tenant" value="Customer Azure Tenant / Subscription   —   one state file &amp; deployment boundary per environment (dev · staging · prod)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#666666;fillColor=#fbfbfb;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="1530" height="700" as="geometry"/></mxCell>

        <!-- HUB VNET -->
        <mxCell id="hubvnet" value="Hub VNet — shared-services (own state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf1fb;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="70" y="540" width="380" height="600" as="geometry"/></mxCell>
        <mxCell id="fw" value="Azure Firewall — OPTIONAL (deploy_firewall = true, ADR-0007)&#10;egress allowlist · forced tunneling&#10;inspects all spoke 0.0.0.0/0 egress (prod/client posture)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="95" y="600" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="nat" value="Hub NAT Gateway — OPTIONAL (with firewall)&#10;stable, auditable outbound public IP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="95" y="686" width="330" height="56" as="geometry"/></mxCell>
        <mxCell id="pdns" value="Private DNS Zones (linked to spoke VNet)&#10;privatelink.blob.core.windows.net&#10;privatelink.dfs.core.windows.net&#10;privatelink.vaultcore.azure.net&#10;privatelink.azuredatabricks.net" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="95" y="762" width="330" height="118" as="geometry"/></mxCell>
        <mxCell id="sync" value="Identity &amp; UC bootstrap (shared-services)&#10;Entra → Databricks account group sync (SCIM)&#10;UC metastore deployed here (account-level)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="95" y="900" width="330" height="86" as="geometry"/></mxCell>
        <mxCell id="azpolicy" value="Azure Policy guardrails&#10;require tags · deny public storage · require NSGs · allowed regions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="95" y="1006" width="330" height="110" as="geometry"/></mxCell>

        <!-- SPOKE VNET -->
        <mxCell id="spokevnet" value="Spoke VNet — Databricks workload (VNet injection · /16–/24)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf1fb;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="470" y="540" width="580" height="600" as="geometry"/></mxCell>

        <!-- SCC security boundary -->
        <mxCell id="sccbound" value="Secure Cluster Connectivity — no public IP · no inbound ports" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;dashed=1;dashPattern=6 4;verticalAlign=top;fontStyle=2;fontSize=11;fontColor=#b85450;align=center;spacingTop=2;" vertex="1" parent="1"><mxGeometry x="490" y="592" width="270" height="288" as="geometry"/></mxCell>
        <mxCell id="host" value="Host Subnet (delegated)&#10;Microsoft.Databricks/workspaces&#10;NSG (network intent policy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="505" y="622" width="240" height="70" as="geometry"/></mxCell>
        <mxCell id="cont" value="Container Subnet (delegated)&#10;Microsoft.Databricks/workspaces&#10;NSG (network intent policy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="505" y="704" width="240" height="70" as="geometry"/></mxCell>
